rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - purchasesCount: number (required)
    //   - role: string (required, 'user' or 'admin')
    //
    // Collection: products
    // Document ID: {productId}
    // Fields: id, name, price, category, image, description, sizes, colors, backImage, additionalImages
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields: id, userId, items, total, status, createdAt, customerName, customerPhone
    //
    // Collection: settings
    // Document ID: {settingId}
    // Fields: heroTitle, heroSubtitle, aboutText
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isAdmin() {
      let isEmailAdmin = isAuthenticated() && ('email' in request.auth.token) && (request.auth.token.email == "shaironquintano37@gmail.com" || request.auth.token.email == "Shaironquintano37@gmail.com");
      let hasUserDoc = isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      let isDbAdmin = hasUserDoc && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      return isEmailAdmin || isDbAdmin;
    }
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'purchasesCount', 'role']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             data.purchasesCount is number && data.purchasesCount >= 0 &&
             data.role in ['user', 'admin'];
    }
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 1000000 &&
             (!('backImage' in data) || (data.backImage is string && data.backImage.size() < 1000000)) &&
             (!('additionalImages' in data) || (data.additionalImages is list && data.additionalImages.size() < 10)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('sizes' in data) || (data.sizes is list && data.sizes.size() < 20)) &&
             (!('colors' in data) || (data.colors is list && data.colors.size() < 20)) &&
             (!('id' in data) || (data.id is string && data.id.size() < 100));
    }
    function isValidOrder(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.items is string && data.items.size() > 0 && data.items.size() < 1000000 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() < 100 &&
             (!('customerName' in data) || (data.customerName is string && data.customerName.size() < 200)) &&
             (!('customerPhone' in data) || (data.customerPhone is string && data.customerPhone.size() < 50)) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() < 100));
    }
    function isValidSettings(data) {
      return (!('heroTitle' in data) || (data.heroTitle is string && data.heroTitle.size() < 500)) &&
             (!('heroSubtitle' in data) || (data.heroSubtitle is string && data.heroSubtitle.size() < 1000)) &&
             (!('aboutText' in data) || (data.aboutText is string && data.aboutText.size() < 5000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Create: User can create their own profile. Role must be 'user' unless created by admin.
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidUnchanged() &&
                    ((request.resource.data.role == 'user') || isAdmin());
                    
      // Update: User can update their own profile, but cannot change role or uid. Admins can update any profile.
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    uidNotModified() &&
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
                    
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isValidOrder(request.resource.data) && (
        (isAuthenticated() && request.resource.data.userId == request.auth.uid) ||
        (!isAuthenticated() && request.resource.data.userId == 'anonymous')
      );
      allow update: if isAdmin() && request.resource.data.status in ['pending', 'completed', 'cancelled'];
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
